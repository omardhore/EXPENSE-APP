# Copy this file to `.env.local` and fill in your Supabase project values.
# Do NOT commit `.env.local` to version control.

# Your Supabase project URL (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public API key (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: server-only key for admin operations (do not expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: set the Next.js port for `next dev` (default 3000)
# PORT=3000
